# Copy to config/profiles/nas.env for deployment from your local machine.

NOCTRA_BIND_HOST=0.0.0.0
NOCTRA_HEALTHCHECK_HOST=127.0.0.1
NOCTRA_PORT=8888

# NAS media mounts inside the container
NOCTRA_SOURCE_DIR=/vol2/1000/porn/ChaosJAV
NOCTRA_DIST_DIR=/vol2/1000/porn/OrderedJAV

# Recommended: keep SQLite on the NAS data volume, not under /home
NOCTRA_DATA_DIR=/vol2/1000/appdata/noctra/data
NOCTRA_DB_PATH="$NOCTRA_DATA_DIR/noctra.db"

# Remote deployment target
NOCTRA_REMOTE_HOST=nas-jieliu
NOCTRA_REMOTE_PATH=/home/jieliu/noctra
NOCTRA_REMOTE_PYTHON_BIN=python3

# Deployment mode: python | docker | docker-image
NOCTRA_REMOTE_DEPLOY_MODE=docker-image
NOCTRA_REMOTE_COMPOSE_FILE=docker-compose.nas-image.yml
NOCTRA_REMOTE_DOCKER_PROJECT_NAME=noctra
NOCTRA_DOCKER_IMAGE=acyua/noctra:latest
NOCTRA_DOCKER_PULL_POLICY=always
NOCTRA_WATCHTOWER_IMAGE=containrrr/watchtower:latest
NOCTRA_WATCHTOWER_INTERVAL=300
NOCTRA_TIMEZONE=Asia/Shanghai
NOCTRA_PYTHON_BASE_IMAGE=docker.m.daocloud.io/library/python:3.11-slim
NOCTRA_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NOCTRA_PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
