# Copy to config/profiles/local.env and adjust only if you want to override
# the repo-relative defaults.

NOCTRA_BIND_HOST=127.0.0.1
NOCTRA_HEALTHCHECK_HOST=127.0.0.1
NOCTRA_PORT=8888

NOCTRA_SOURCE_DIR="$NOCTRA_REPO_ROOT/test_data/source"
NOCTRA_DIST_DIR="$NOCTRA_REPO_ROOT/test_data/dist"
NOCTRA_DATA_DIR="$NOCTRA_REPO_ROOT/data"
NOCTRA_DB_PATH="$NOCTRA_DATA_DIR/noctra.db"

# Optional overrides
# NOCTRA_PYTHON_BIN="$NOCTRA_REPO_ROOT/.venv/bin/python"
